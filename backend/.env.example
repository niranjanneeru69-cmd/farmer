# ─── Server Configuration ──────────────────────────────
PORT=8000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.onrender.com

# ─── Database Configuration (MySQL) ────────────────────
# Option A: Single Connection URL (Preferred for cloud hosting e.g. Aiven)
DATABASE_URL=mysql://user:password@host:port/database

# Option B: Individual Credentials (Used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=farmiti_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_SSL=false

# ─── Authentication Secrets ────────────────────────────
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
JWT_EXPIRES_IN=7d

# ─── Google Gemini AI ──────────────────────────────────
# Add multiple keys separated by commas for rotating fallback
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# ─── Grok / Groq AI ────────────────────────────────────
GROK_API_KEYS=your_grok_api_key

# ─── OpenWeatherMap API ────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key

# ─── Cloudinary Configuration (Production Uploads) ─────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Email / OTP SMTP Settings (Nodemailer) ────────────
EMAIL_USER=your_email_sender@gmail.com
EMAIL_PASS=your_email_app_specific_password

# ─── File Upload Restraints ───────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
